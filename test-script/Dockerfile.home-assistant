  FROM debian:13

  RUN apt-get update && apt-get install -y \
      python3 python3-pip python3-venv \
      systemd openssh-server \
      && rm -rf /var/lib/apt/lists/*

  RUN python3 -m venv /opt/homeassistant \
      && /opt/homeassistant/bin/pip install homeassistant

  RUN mkdir -p /run/sshd && ssh-keygen -A \
      && sed -i 's/#PermitRootLogin .*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config \
      && systemctl enable ssh

  # Home Assistant systemd service
RUN printf '[Unit]\nDescription=Home Assistant\nAfter=network.target\n\n[Service]\nExecStart=/opt/homeassistant/bin/hass -c /root/.homeassistant\nRestart=always\n\n[Install]\nWantedBy=multi-user.target\n' > /etc/systemd/system/homeassistant.service \
    && systemctl enable homeassistant
  EXPOSE 8123
